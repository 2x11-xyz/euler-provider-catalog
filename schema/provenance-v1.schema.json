{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/2x11-xyz/euler-provider-catalog/main/schema/provenance-v1.schema.json",
  "title": "Euler provider catalog provenance v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "generator",
    "providers"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "euler-provider-catalog"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "providers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/provider_provenance"
      }
    }
  },
  "$defs": {
    "provider_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discovery_kind",
        "documentation_urls",
        "observed_at",
        "inputs",
        "observed_model_count",
        "published_model_count",
        "curated_model_count",
        "skipped",
        "warnings"
      ],
      "properties": {
        "discovery_kind": {
          "enum": [
            "official_api",
            "curated"
          ]
        },
        "documentation_urls": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/input"
          }
        },
        "observed_model_count": {
          "type": "integer",
          "minimum": 0
        },
        "published_model_count": {
          "type": "integer",
          "minimum": 1
        },
        "curated_model_count": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "warnings": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "type": "string",
            "maxLength": 512
          }
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "kind": {
          "enum": [
            "official_api",
            "curated",
            "source_policy"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16777216
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
