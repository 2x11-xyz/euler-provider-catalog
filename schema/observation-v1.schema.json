{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/2x11-xyz/euler-provider-catalog/main/schema/observation-v1.schema.json",
  "title": "Euler provider source observation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provider_id",
    "observed_at",
    "inputs"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "provider_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "endpoint_id",
          "file",
          "source_url",
          "bytes",
          "sha256"
        ],
        "properties": {
          "endpoint_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{0,63}$"
          },
          "file": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]{0,127}\\.json$"
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "bytes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 16777216
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
