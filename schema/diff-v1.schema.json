{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/2x11-xyz/euler-provider-catalog/main/schema/diff-v1.schema.json",
  "title": "Euler provider catalog promotion diff v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "from_release_id",
    "from_generated_at",
    "from_minimum_euler_version",
    "to_release_id",
    "to_generated_at",
    "to_minimum_euler_version",
    "decision",
    "reasons",
    "promotion_policy",
    "providers"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "from_release_id": {
      "oneOf": [
        {
          "$ref": "#/$defs/release_id"
        },
        {
          "type": "null"
        }
      ]
    },
    "to_release_id": {
      "$ref": "#/$defs/release_id"
    },
    "from_generated_at": {
      "oneOf": [
        {
          "$ref": "#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "from_minimum_euler_version": {
      "oneOf": [
        {
          "$ref": "#/$defs/version"
        },
        {
          "type": "null"
        }
      ]
    },
    "to_generated_at": {
      "$ref": "#/$defs/timestamp"
    },
    "to_minimum_euler_version": {
      "$ref": "#/$defs/version"
    },
    "decision": {
      "enum": [
        "no_change",
        "addition_only",
        "review_required",
        "blocked"
      ]
    },
    "reasons": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "enum": [
          "bootstrap",
          "provider_set_changed",
          "provider_metadata_changed",
          "model_addition",
          "model_removal",
          "model_lifecycle_changed",
          "model_metadata_changed",
          "minimum_euler_version_changed",
          "non_monotonic_release",
          "source_policy_changed",
          "curated_input_changed",
          "excessive_shrink"
        ]
      }
    },
    "promotion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha256",
        "maximum_shrink_basis_points"
      ],
      "properties": {
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "maximum_shrink_basis_points": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        }
      }
    },
    "providers": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 32,
      "patternProperties": {
        "^[a-z][a-z0-9-]{0,63}$": {
          "$ref": "#/$defs/provider_diff"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "release_id": {
      "type": "string",
      "pattern": "^catalog-v1-[0-9]{8}t[0-9]{6}z-[a-f0-9]{64}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "model_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!.*::)[^\\s]+$"
    },
    "model_ids": {
      "type": "array",
      "maxItems": 10000,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/model_id"
      }
    },
    "provider_diff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "before_model_count",
        "after_model_count",
        "shrink_basis_points",
        "provider_fields_changed",
        "models_added",
        "models_removed",
        "lifecycle_changes",
        "metadata_changes",
        "source_policy_changed",
        "curated_input_changed"
      ],
      "properties": {
        "before_model_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "after_model_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "shrink_basis_points": {
          "description": "Ceiling of removed models divided by the previous model count, in hundredths of one percent.",
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "provider_fields_changed": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": [
              "aliases",
              "default_model",
              "display_name"
            ]
          }
        },
        "models_added": {
          "$ref": "#/$defs/model_ids"
        },
        "models_removed": {
          "$ref": "#/$defs/model_ids"
        },
        "lifecycle_changes": {
          "type": "array",
          "maxItems": 10000,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "before",
              "after"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/model_id"
              },
              "before": {
                "$ref": "#/$defs/status"
              },
              "after": {
                "$ref": "#/$defs/status"
              }
            }
          }
        },
        "metadata_changes": {
          "type": "array",
          "maxItems": 10000,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "fields"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/model_id"
              },
              "fields": {
                "type": "array",
                "minItems": 1,
                "maxItems": 6,
                "uniqueItems": true,
                "items": {
                  "enum": [
                    "context_window_tokens",
                    "display_name",
                    "max_output_tokens",
                    "reasoning_efforts",
                    "supports_reasoning",
                    "supports_tools"
                  ]
                }
              }
            }
          }
        },
        "source_policy_changed": {
          "type": "boolean"
        },
        "curated_input_changed": {
          "type": "boolean"
        }
      }
    },
    "status": {
      "enum": [
        "active",
        "deprecated",
        "removed"
      ]
    }
  }
}
