{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/2x11-xyz/euler-provider-catalog/main/schema/manifest-v1.schema.json",
  "title": "Euler provider catalog manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "generated_at",
    "minimum_euler_version",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "release_id": {
      "type": "string",
      "pattern": "^catalog-v1-[0-9]{8}t[0-9]{6}z-[a-f0-9]{64}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "minimum_euler_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog-v1.json",
        "provenance-v1.json"
      ],
      "properties": {
        "catalog-v1.json": {
          "$ref": "#/$defs/artifact"
        },
        "provenance-v1.json": {
          "$ref": "#/$defs/artifact"
        }
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bytes",
        "sha256"
      ],
      "properties": {
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16777216
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
