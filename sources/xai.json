{
  "schema_version": 1,
  "provider_id": "xai",
  "display_name": "xAI",
  "normalizer": "xai",
  "minimum_euler_version": "0.1.1",
  "discovery": {
    "kind": "official_api",
    "endpoints": [
      {
        "id": "models",
        "url": "https://api.x.ai/v1/models",
        "file": "models.json"
      },
      {
        "id": "language-models",
        "url": "https://api.x.ai/v1/language-models",
        "file": "language-models.json"
      }
    ],
    "documentation_urls": [
      "https://docs.x.ai/developers/rest-api-reference/inference/models",
      "https://docs.x.ai/developers/models",
      "https://docs.x.ai/developers/tools/function-calling",
      "https://docs.x.ai/developers/model-capabilities/text/reasoning",
      "https://docs.x.ai/developers/migration/may-15-retirement"
    ]
  },
  "field_ownership": {
    "membership": "official_api.language_models.models[] ids and aliases plus reviewed deprecated redirect slugs",
    "id": "official_api.language_models.models[].id",
    "display_name": "official_id with reviewed overrides",
    "context_window_tokens": "official_api.models.data[].context_length",
    "max_output_tokens": "omitted unless an official source publishes a limit",
    "supports_tools": "official_function_calling_contract",
    "supports_reasoning": "official_model_documentation when reviewed",
    "reasoning_efforts": "official_model_documentation when reviewed",
    "status": "official_retirement_documentation with reviewed fallback",
    "default_model": "euler_curated"
  },
  "filters": {
    "required_object_type": "model",
    "required_owned_by": [
      "xai"
    ],
    "required_output_modalities": [
      "text"
    ]
  },
  "limits": {
    "max_response_bytes": 2097152,
    "minimum_observed_models": 2,
    "minimum_published_models": 2,
    "maximum_published_models": 1000,
    "maximum_model_id_bytes": 256,
    "maximum_display_name_bytes": 256,
    "maximum_token_limit": 20000000
  }
}
